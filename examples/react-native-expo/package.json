{
  "name": "zntc-example-react-native-expo",
  "version": "1.0.0",
  "private": true,
  "description": "ZNTC dev server + bundler example — Expo 55 / RN 0.83",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:zntc": "zntc dev --platform=react-native --rn-platform=ios index.js",
    "prestart:zntc": "bun run build:zntc:core",
    "build:zntc:core": "bun install --cwd ../.. --frozen-lockfile && bun run --cwd ../../packages/core build:local && bun run --cwd ../../packages/server build && bun run --cwd ../../packages/react-native build",
    "bundle:zntc:ios": "zntc bundle index.js --platform=react-native --rn-platform=ios -o dist/main.ios.jsbundle",
    "bundle:zntc:android": "zntc bundle index.js --platform=react-native --rn-platform=android -o dist/main.android.jsbundle",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.14",
    "@react-navigation/native": "^7.1.33",
    "expo": "~55.0.15",
    "expo-constants": "~55.0.14",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.8",
    "expo-linking": "~55.0.13",
    "expo-router": "~55.0.12",
    "expo-splash-screen": "~55.0.18",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.15",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "~4.3.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "~0.8.1"
  },
  "devDependencies": {
    "@react-native-community/cli-server-api": "^15.0.0",
    "@react-native/dev-middleware": "^0.83.1",
    "@react-navigation/core": "^7.17.4",
    "@rozenite/controls-plugin": "^1.8.1",
    "@rozenite/expo-atlas-plugin": "^1.8.1",
    "@rozenite/metro": "^1.8.1",
    "@rozenite/network-activity-plugin": "^1.8.1",
    "@rozenite/react-navigation-plugin": "^1.8.1",
    "@rozenite/redux-devtools-plugin": "^1.8.1",
    "@rozenite/require-profiler-plugin": "^1.8.1",
    "@rozenite/sqlite-plugin": "^1.8.1",
    "@rozenite/storage-plugin": "^1.8.1",
    "@rozenite/tanstack-query-plugin": "^1.8.1",
    "@tanstack/react-query": "^5",
    "@types/react": "~19.2.10",
    "@zntc/core": "workspace:*",
    "@zntc/react-native": "workspace:*",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "typescript": "~5.9.2"
  }
}
