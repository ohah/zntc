{
  "name": "zntc-example-react-native-bare",
  "version": "0.0.1",
  "private": true,
  "description": "ZNTC dev server + bundler example — React Native 0.85 bare",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "android:release": "react-native run-android --mode=release",
    "ios:release": "react-native run-ios --mode Release",
    "start": "react-native start",
    "start:zntc": "zntc dev --platform=react-native --rn-platform=ios index.js",
    "prestart:zntc": "bun run build:zntc:core",
    "build:zntc:core": "bun run --cwd ../../packages/core build && bun run --cwd ../../packages/server build && bun run --cwd ../../packages/react-native build",
    "bundle:zntc:ios": "zntc bundle index.js --platform=react-native --rn-platform=ios -o ios/main.jsbundle",
    "bundle:zntc:android": "zntc bundle index.js --platform=react-native --rn-platform=android -o android/app/src/main/assets/index.android.bundle",
    "bundle:metro:ios": "react-native bundle --platform ios --dev false --entry-file index.js --bundle-output ios/main.jsbundle --assets-dest ios",
    "bundle:metro:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "test": "jest"
  },
  "dependencies": {
    "@react-native/new-app-screen": "0.85.1",
    "react": "19.2.3",
    "react-native": "0.85.1",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-worklets": "^0.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/plugin-transform-flow-strip-types": "^7.27.1",
    "@babel/plugin-transform-private-methods": "^7.28.6",
    "@babel/preset-env": "^7.25.3",
    "@babel/preset-flow": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.3",
    "@react-native-community/cli-platform-android": "20.1.3",
    "@react-native-community/cli-platform-ios": "20.1.3",
    "@react-native-community/cli-server-api": "^15.0.0",
    "@react-native/babel-plugin-codegen": "0.85.1",
    "@react-native/babel-preset": "0.85.1",
    "@react-native/codegen": "0.85.1",
    "@react-native/dev-middleware": "^0.83.1",
    "@react-native/gradle-plugin": "0.85.1",
    "@react-native/metro-config": "0.85.1",
    "@react-native/typescript-config": "0.85.1",
    "@rozenite/metro": "^1.7.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.3",
    "@types/react-test-renderer": "^19.1.0",
    "@zntc/core": "workspace:*",
    "@zntc/react-native": "workspace:*",
    "babel-plugin-lodash": "^3.3.4",
    "babel-plugin-root-import": "^6.6.0",
    "jest": "^29.6.3",
    "lodash": "^4.18.1",
    "react-native-svg": "^15.15.4",
    "react-native-svg-transformer": "^1.5.3",
    "react-refresh": "^0.18.0",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
