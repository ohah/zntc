{
  "name": "@zntc/example-rspack",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "bun run --cwd ../../packages/core build:js && bun run --cwd ../../packages/rspack-loader build",
