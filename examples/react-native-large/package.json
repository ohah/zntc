{
  "name": "zntc-example-react-native-large",
  "version": "0.0.1",
  "private": true,
  "description": "ZNTC bundler example — large RN app (navigation + query + redux + forms + icons + charts) for cold-build perf testing",
  "scripts": {
    "start:zntc": "zntc dev --platform=react-native --rn-platform=ios index.js",
    "prestart:zntc": "bun run build:zntc:core",
    "build:zntc:core": "bun install --cwd ../.. --frozen-lockfile && bun run --cwd ../../packages/core build:local && bun run --cwd ../../packages/server build && bun run --cwd ../../packages/react-native build",
    "bundle:zntc:ios": "zntc bundle index.js --platform=react-native --rn-platform=ios -o ios/main.jsbundle",
    "bundle:zntc:android": "zntc bundle index.js --platform=react-native --rn-platform=android -o android/app/src/main/assets/index.android.bundle",
    "bundle:metro:ios": "react-native bundle --platform ios --dev false --entry-file index.js --bundle-output ios/main.jsbundle --assets-dest ios",
    "bundle:metro:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res"
  },
