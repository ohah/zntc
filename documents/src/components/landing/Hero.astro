---
import { Code } from "astro:components";

interface Action {
  text: string;
  href: string;
  primary?: boolean;
}

interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  actions: Action[];
  codeExample: string;
  codeLang?: string;
  codeFilename?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  actions,
  codeExample,
  codeLang = "ts",
  codeFilename,
} = Astro.props;
---

<section class="not-content relative overflow-hidden">
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute -top-32 -left-16 h-96 w-96 rounded-full bg-zig-500/15 blur-3xl"></div>
    <div class="absolute bottom-0 right-1/3 h-80 w-80 rounded-full bg-zig-600/10 blur-3xl"></div>
  </div>
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-24 lg:py-28">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-14">
      <div class="flex flex-col gap-6">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-zig-400">
          {eyebrow}
        </p>
        <h1 class="text-4xl font-bold leading-[1.1] tracking-tight sm:text-5xl lg:text-6xl">
          <span class="bg-gradient-to-br from-zig-200 via-zig-400 to-zig-600 bg-clip-text text-transparent">
            {title}
          </span>
        </h1>
        <p class="max-w-xl text-lg leading-relaxed text-[color:var(--sl-color-gray-2)]">
          {subtitle}
        </p>
        <div class="mt-2 flex flex-wrap gap-3">
          {
            actions.map((a) => (
              <a
                href={a.href}
                class:list={[
                  "inline-flex items-center gap-2 rounded-md px-4 py-2 text-sm font-semibold transition-colors",
                  a.primary
                    ? "bg-zig-500 text-zig-950 hover:bg-zig-400"
                    : "border border-[color:var(--sl-color-gray-5)] text-[color:var(--sl-color-white)] hover:border-zig-500 hover:text-zig-400",
                ]}
              >
                {a.text}
              </a>
            ))
          }
        </div>
      </div>
      <div class="relative">
        <div class="absolute -inset-1 -z-10 rounded-xl bg-gradient-to-br from-zig-500/25 to-zig-700/10 blur-xl"></div>
        <div class="overflow-hidden rounded-lg border border-[color:var(--sl-color-gray-5)] bg-[color:var(--sl-color-black)] shadow-2xl shadow-black/40">
          {
            codeFilename && (
              <div class="flex items-center gap-2 border-b border-[color:var(--sl-color-gray-5)] px-4 py-2">
                <span class="h-3 w-3 rounded-full bg-[#ff5f57]" />
                <span class="h-3 w-3 rounded-full bg-[#febc2e]" />
                <span class="h-3 w-3 rounded-full bg-[#28c840]" />
                <span class="ml-2 font-mono text-xs text-[color:var(--sl-color-gray-3)]">
                  {codeFilename}
                </span>
              </div>
            )
          }
          <div class="[&_pre]:!m-0 [&_pre]:!border-0 [&_pre]:!rounded-none [&_pre]:!p-4">
            <Code code={codeExample} lang={codeLang} theme="github-dark" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
