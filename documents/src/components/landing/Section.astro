---
interface Props {
  variant?: "plain" | "strip";
  padding?: string;
  class?: string;
}

const {
  variant = "plain",
  padding = "py-20",
  class: className = "",
} = Astro.props;

const stripClass =
  variant === "strip"
    ? "border-y border-[color:var(--sl-color-gray-5)] bg-[color:var(--sl-color-gray-7)]/30"
    : "";
---

<section class:list={["not-content", stripClass, className]}>
  <div class:list={["mx-auto max-w-6xl px-6", padding]}>
    <slot />
  </div>
</section>
