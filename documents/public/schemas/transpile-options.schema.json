{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ohah.github.io/zts/schemas/transpile-options.schema.json",
  "title": "ZTS Transpile Options",
  "description": "Options for the ZTS transpiler. Generated from Zig `TranspileOptionsDto` — edit src/transpile.zig and run `zig build schema` to regenerate.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "target": {"type": "string", "enum": ["es5", "es2015", "es2016", "es2017", "es2018", "es2019", "es2020", "es2021", "es2022", "es2023", "es2024", "es2025", "esnext"], "description": "ES downlevel target. Unset = esnext (no feature lowering)."},
    "unsupported": {"type": "integer", "minimum": 0, "maximum": 4294967295, "description": "Direct unsupported feature bitmask (browserslist override). Takes precedence over `target`."},
    "flow": {"type": "boolean", "description": "Enable Flow type stripping."},
    "jsxInJs": {"type": "boolean", "description": "Allow JSX in `.js`/`.jsx` files (not just `.tsx`)."},
    "jsx": {"type": "string", "enum": ["classic", "automatic", "automatic_dev"], "description": "JSX runtime. `classic` = React.createElement, `automatic` = jsx-runtime import."},
    "jsxFactory": {"type": "string", "description": "Classic-mode JSX factory (default: React.createElement)."},
    "jsxFragment": {"type": "string", "description": "Classic-mode Fragment factory (default: React.Fragment)."},
    "jsxImportSource": {"type": "string", "description": "Automatic-mode import source (default: react)."},
    "dropConsole": {"type": "boolean", "description": "Remove `console.*` calls."},
    "dropDebugger": {"type": "boolean", "description": "Remove `debugger` statements."},
    "asciiOnly": {"type": "boolean", "description": "Escape non-ASCII characters as hex escape sequences."},
    "charsetUtf8": {"type": "boolean", "description": "Preserve non-ASCII characters verbatim."},
    "experimentalDecorators": {"type": "boolean", "description": "Legacy TC39 stage-1 decorators."},
    "emitDecoratorMetadata": {"type": "boolean", "description": "Emit decorator metadata (requires experimentalDecorators)."},
    "useDefineForClassFields": {"type": "boolean", "description": "Use `[[Define]]` semantics for class fields (default: true)."},
    "format": {"type": "string", "enum": ["esm", "cjs"], "description": "Module format for the output."},
    "quotes": {"type": "string", "enum": ["double", "single", "preserve"], "description": "Preferred string quote style."},
    "platform": {"type": "string", "enum": ["browser", "node", "neutral", "react_native"], "description": "Target platform — affects built-in externals and Node polyfills."},
    "minifyWhitespace": {"type": "boolean", "description": "Remove whitespace."},
    "minifyIdentifiers": {"type": "boolean", "description": "Mangle local identifiers."},
    "minifySyntax": {"type": "boolean", "description": "Apply syntax-level minification."},
    "sourcemap": {"type": "boolean", "description": "Generate sourcemap JSON."},
    "sourcemapDebugIds": {"type": "boolean", "description": "Embed Sentry-compatible Debug IDs."},
    "sourcesContent": {"type": "boolean", "description": "Include original source in sourcemap (default: true)."},
    "sourceRoot": {"type": "string", "description": "SourceMap `sourceRoot` field."},
    "define": {"type": "array", "items": {"type": "object", "properties": {"key": {"type": "string"}, "value": {"type": "string"}}, "additionalProperties": false}, "description": "Define list: `{ key, value }` pairs. `value` is raw JSON (strings must include quotes)."}
  }
}
