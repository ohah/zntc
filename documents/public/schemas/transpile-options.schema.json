{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ohah.github.io/zntc/schemas/transpile-options.schema.json",
  "title": "ZNTC Transpile Options",
  "description": "Options for the ZNTC transpiler. Generated from Zig `TranspileOptionsDto` — edit src/transpile/options.zig and run `zig build schema` to regenerate.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "target": {"type": "string", "enum": ["es5", "es2015", "es2016", "es2017", "es2018", "es2019", "es2020", "es2021", "es2022", "es2023", "es2024", "es2025", "esnext"], "description": "ES downlevel target. Unset = esnext (no feature lowering)."},
    "unsupported": {"type": "integer", "minimum": 0, "maximum": 4294967295, "description": "Direct unsupported feature bitmask (browserslist override). Takes precedence over `target`."},
    "flow": {"type": "boolean", "description": "Enable Flow type stripping."},
    "jsxInJs": {"type": "boolean", "description": "Allow JSX in `.js`/`.jsx` files (not just `.tsx`)."},
    "reactRefresh": {"type": "boolean"},
    "reactRefreshHookSignatures": {"type": "boolean"},
    "jsx": {"type": "string", "enum": ["classic", "automatic", "automatic_dev", "preserve"], "description": "JSX runtime. `classic` = React.createElement, `automatic` = jsx-runtime import."},
    "jsxFactory": {"type": "string", "description": "Classic-mode JSX factory (default: React.createElement)."},
    "jsxFragment": {"type": "string", "description": "Classic-mode Fragment factory (default: React.Fragment)."},
    "jsxImportSource": {"type": "string", "description": "Automatic-mode import source (default: react)."},
    "dropConsole": {"type": "boolean", "description": "Remove `console.*` calls."},
    "dropDebugger": {"type": "boolean", "description": "Remove `debugger` statements."},
    "asciiOnly": {"type": "boolean", "description": "Escape non-ASCII characters as hex escape sequences."},
    "charsetUtf8": {"type": "boolean", "description": "Preserve non-ASCII characters verbatim."},
    "experimentalDecorators": {"type": "boolean", "description": "Legacy TC39 stage-1 decorators."},
    "emitDecoratorMetadata": {"type": "boolean", "description": "Emit decorator metadata (requires experimentalDecorators)."},
    "useDefineForClassFields": {"type": "boolean", "description": "Use `[[Define]]` semantics for class fields (default: true)."},
    "verbatimModuleSyntax": {"type": "boolean"},
    "tsconfigPath": {"type": "string"},
    "tsconfigRaw": {"type": "string"},
    "format": {"type": "string", "enum": ["esm", "cjs"], "description": "Module format for the output."},
    "quotes": {"type": "string", "enum": ["double", "single", "preserve"], "description": "Preferred string quote style."},
    "platform": {"type": "string", "enum": ["browser", "node", "neutral", "react_native"], "description": "Target platform — affects built-in externals and Node polyfills."},
    "minify": {"type": "boolean"},
    "minifyWhitespace": {"type": "boolean", "description": "Remove whitespace."},
    "minifyIdentifiers": {"type": "boolean", "description": "Mangle local identifiers."},
    "minifySyntax": {"type": "boolean", "description": "Apply syntax-level minification."},
    "sourcemap": {"type": "boolean", "description": "Generate sourcemap JSON."},
    "sourcemapMode": {"type": "string"},
    "outputExports": {"type": "string"},
    "sourcemapDebugIds": {"type": "boolean", "description": "Embed Sentry-compatible Debug IDs."},
    "sourcesContent": {"type": "boolean", "description": "Include original source in sourcemap (default: true)."},
    "sourceRoot": {"type": "string", "description": "SourceMap `sourceRoot` field."},
    "define": {"type": "array", "items": {"type": "object", "properties": {"key": {"type": "string"}, "value": {"type": "string"}}, "additionalProperties": false}, "description": "Define list: `{ key, value }` pairs. `value` is raw JSON (strings must include quotes)."},
    "stopAfter": {"type": "string", "enum": ["scan", "parse", "semantic", "transform", "codegen"]},
    "external": {"type": "array", "items": {"type": "string"}},
    "alias": {"type": "array", "items": {"type": "object", "properties": {"from": {"type": "string"}, "to": {"type": "string"}, "exact": {"type": "boolean"}}, "additionalProperties": false}},
    "loader": {"type": "array", "items": {"type": "object", "properties": {"ext": {"type": "string"}, "loader": {"type": "string"}}, "additionalProperties": false}},
    "conditions": {"type": "array", "items": {"type": "string"}},
    "resolveExtensions": {"type": "array", "items": {"type": "string"}},
    "mainFields": {"type": "array", "items": {"type": "string"}},
    "banner": {"type": "string"},
    "footer": {"type": "string"},
    "intro": {"type": "string"},
    "outro": {"type": "string"},
    "assetNames": {"type": "string"},
    "assetInlineLimit": {"type": "integer", "minimum": 0, "maximum": 4294967295, "description": "Inline assets at or below this size (bytes) as data URLs instead of emitting files. 0 disables inlining (default: 4096)."},
    "chunkNames": {"type": "string"},
    "entryNames": {"type": "string"},
    "preserveModules": {"type": "boolean"},
    "preserveModulesRoot": {"type": "string"},
    "inlineDynamicImports": {"type": "boolean"},
    "minChunkSize": {"type": "integer", "minimum": 0, "maximum": 4294967295},
    "manualChunks": {"type": "array", "items": {"type": "object", "properties": {"name": {"type": "string"}, "patterns": {"type": "array", "items": {"type": "string"}}}, "additionalProperties": false}},
    "mf": {{"type": "object", "properties": {"name": {"type": "string"}, "exposes": {{"type": "object", "properties": {"map": {{"type": "object", "properties": {"entries": {{"type": "object", "properties": {"bytes": {"type": "null"}, "len": {"type": "integer", "minimum": 0, "maximum": 18446744073709551615}, "capacity": {"type": "integer", "minimum": 0, "maximum": 18446744073709551615}}, "additionalProperties": false}}, "index_header": {"type": "null"}, "pointer_stability": {{"type": "object", "properties": {"state": {"type": "string", "enum": ["unlocked", "locked"]}}, "additionalProperties": false}}}, "additionalProperties": false}}}, "additionalProperties": false}}, "remotes": {{"type": "object", "properties": {"map": {{"type": "object", "properties": {"entries": {{"type": "object", "properties": {"bytes": {"type": "null"}, "len": {"type": "integer", "minimum": 0, "maximum": 18446744073709551615}, "capacity": {"type": "integer", "minimum": 0, "maximum": 18446744073709551615}}, "additionalProperties": false}}, "index_header": {"type": "null"}, "pointer_stability": {{"type": "object", "properties": {"state": {"type": "string", "enum": ["unlocked", "locked"]}}, "additionalProperties": false}}}, "additionalProperties": false}}}, "additionalProperties": false}}, "shared": {{"type": "object", "properties": {"map": {{"type": "object", "properties": {"entries": {{"type": "object", "properties": {"bytes": {"type": "null"}, "len": {"type": "integer", "minimum": 0, "maximum": 18446744073709551615}, "capacity": {"type": "integer", "minimum": 0, "maximum": 18446744073709551615}}, "additionalProperties": false}}, "index_header": {"type": "null"}, "pointer_stability": {{"type": "object", "properties": {"state": {"type": "string", "enum": ["unlocked", "locked"]}}, "additionalProperties": false}}}, "additionalProperties": false}}}, "additionalProperties": false}}, "shareScope": {"type": "string"}, "shareStrategy": {"type": "string"}}, "additionalProperties": false}}
  }
}
