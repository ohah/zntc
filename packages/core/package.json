{
  "name": "@zts/core",
  "version": "0.1.0",
  "description": "ZTS TypeScript transpiler — native binding",
  "license": "MIT",
  "files": [
    "dist/",
    "zts.node"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build:napi": "cd ../.. && zig build napi",
    "build:js": "bun build index.ts --outdir dist --format esm --target node",
    "build": "bun run build:napi && cp ../../zig-out/lib/zts.node . && bun run build:js",
    "test": "bun test"
  }
}
