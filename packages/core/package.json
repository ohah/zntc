{
  "name": "@zntc/core",
  "version": "0.1.0",
  "description": "ZNTC native transpiler compiler binding",
  "license": "MIT",
  "bin": {
    "zntc": "./bin/zntc.mjs"
  },
  "source": "./index.ts",
  "files": [
    "dist/",
    "bin/cli-flags.mjs",
    "bin/rn-asset-copy.mjs",
    "bin/rn-dev-input.mjs",
    "bin/zntc.mjs",
    "zntc.node"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "source": "./index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build:napi": "cd ../.. && zig build napi",
    "build:js": "bun build index.ts --outdir dist --format esm --target node",
    "build:dts": "bun x tsc -b",
    "build": "bun run build:napi && cp ../../zig-out/lib/zntc.node . && bun run build:js && bun run build:dts",
    "postinstall": "[ -f ../../zig-out/lib/zntc.node ] && cp ../../zig-out/lib/zntc.node . || true",
    "pretest": "bun run --cwd ../server build && bun run --cwd ../web build && bun run --cwd ../react-native build",
    "test": "bun test --timeout 10000"
  },
  "devDependencies": {
    "@types/node": "^25.5.2"
  },
  "optionalDependencies": {
    "browserslist": "^4.24.0",
    "core-js": "^3.49.0",
    "core-js-compat": "^3.49.0",
    "lightningcss": "^1.28.0"
  }
}
