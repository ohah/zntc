{
  "name": "@zts/core",
  "version": "0.1.0",
  "description": "ZTS TypeScript transpiler — native binding",
  "license": "MIT",
  "bin": {
    "zts": "./bin/zts.mjs"
  },
  "files": [
    "dist/",
    "bin/",
    "zts.node"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/core/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/core/index.d.ts"
    }
  },
  "scripts": {
    "build:napi": "cd ../.. && zig build napi",
    "build:js": "bun build index.ts --outdir dist --format esm --target node",
    "build:dts": "bun x tsc --emitDeclarationOnly",
    "build": "bun run build:napi && cp ../../zig-out/lib/zts.node . && bun run build:js && bun run build:dts",
    "postinstall": "[ -f ../../zig-out/lib/zts.node ] && cp ../../zig-out/lib/zts.node . || true",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/node": "^25.5.2"
  },
  "optionalDependencies": {
    "browserslist": "^4.24.0",
    "lightningcss": "^1.28.0"
  }
}
